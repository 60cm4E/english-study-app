  "grammar": {
    "points": [
      {
        "id": "g1",
        "title": "be동사 현재형",
        "explanation": "I → am, You/We/They → are, He/She/It → is. 축약형: I'm, You're, He's 등",
        "examples": [
          {"en": "I am an active person.", "ko": "나는 활동적인 사람이다."},
          {"en": "She is interested in fashion.", "ko": "그녀는 패션에 관심이 있다."},
          {"en": "They are my followers.", "ko": "그들은 나의 팔로워이다."},
          {"en": "It is very helpful.", "ko": "그것은 매우 도움이 된다."}
        ]
      },
      {
        "id": "g2",
        "title": "일반동사 현재형 + 3인칭 단수",
        "explanation": "일반동사는 동작/상태를 나타냅니다. 주어가 3인칭 단수(he/she/it)일 때 동사에 -(e)s를 붙입니다.",
        "examples": [
          {"en": "I exercise every morning.", "ko": "나는 매일 아침 운동한다."},
          {"en": "It records my speed.", "ko": "그것은 내 속도를 기록한다."},
          {"en": "She takes pictures.", "ko": "그녀는 사진을 찍는다."},
          {"en": "He watches movies.", "ko": "그는 영화를 본다."}
        ]
      },
      {
        "id": "g3",
        "title": "인칭대명사",
        "explanation": "주격(I, you, he, she, it, we, they), 소유격(my, your, his, her, its, our, their), 목적격(me, you, him, her, it, us, them), 소유대명사(mine, yours, his, hers, ours, theirs)",
        "examples": [
          {"en": "I love running.", "ko": "나는 달리기를 좋아한다. (주격)"},
          {"en": "My birthday is in May.", "ko": "내 생일은 5월이다. (소유격)"},
          {"en": "Help me, please.", "ko": "나를 도와줘. (목적격)"},
          {"en": "This book is mine.", "ko": "이 책은 내 것이다. (소유대명사)"}
        ]
      },
      {
        "id": "g4",
        "title": "의문문과 부정문",
        "explanation": "be동사 의문문: Be + 주어 ~? 일반동사 의문문: Do/Does + 주어 + 동사원형 ~? 부정문: be + not / do(es) + not + 동사원형",
        "examples": [
          {"en": "Are you a student?", "ko": "너는 학생이니?"},
          {"en": "What do you like?", "ko": "너는 무엇을 좋아하니?"},
          {"en": "Donuts are not just a snack.", "ko": "도넛은 그냥 간식이 아니다."},
          {"en": "I don't like math.", "ko": "나는 수학을 좋아하지 않는다."}
        ]
      }
    ],
    "exercises": [
