  "grammar": {
    "points": [
      {
        "id": "g1",
        "title": "감탄문 (What / How)",
        "explanation": "What + a(n) + 형용사 + 명사 (+ 주어 + 동사)! How + 형용사/부사 (+ 주어 + 동사)!",
        "examples": [
          {"en": "What a nice market!", "ko": "정말 멋진 시장이야!"},
          {"en": "What a beautiful flower!", "ko": "정말 아름다운 꽃이야!"},
          {"en": "How beautiful she is!", "ko": "그녀는 정말 아름다워!"},
          {"en": "How fast he runs!", "ko": "그는 정말 빨리 달려!"}
        ]
      },
      {
        "id": "g2",
        "title": "접속사 that (명사절)",
        "explanation": "think, know, believe, hope, say 등의 동사 뒤에서 목적어 역할. that은 생략 가능.",
        "examples": [
          {"en": "People think (that) I'm tasteless.", "ko": "사람들은 내가 맛없다고 생각한다."},
          {"en": "I believe (that) they are useful.", "ko": "나는 그들이 유용하다고 믿는다."},
          {"en": "She knows (that) he is kind.", "ko": "그녀는 그가 친절하다는 것을 안다."}
        ]
      },
      {
        "id": "g3",
        "title": "because vs because of",
        "explanation": "because + 주어 + 동사 (절). because of + 명사/대명사/동명사.",
        "examples": [
          {"en": "I'm here because I have many spots.", "ko": "나는 점이 많아서 이곳에 왔다. (절)"},
          {"en": "He can't sell me because of my size.", "ko": "내 크기 때문에 나를 팔 수 없다. (명사)"}
        ]
      }
    ],
