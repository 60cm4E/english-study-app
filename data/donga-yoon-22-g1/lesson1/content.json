  "grammar": {
    "points": [
      {
        "id": "g1",
        "title": "be동사 (am, are, is)",
        "explanation": "be동사는 '~이다', '(~에) 있다'라는 뜻입니다. 주어에 따라 am(I), are(you/복수), is(3인칭 단수)를 씁니다. 축약형: I'm, You're, He's, She's, It's, We're, They're",
        "examples": [
          {"en": "I am a student.", "ko": "나는 학생이다."},
          {"en": "You are my friend.", "ko": "너는 내 친구야."},
          {"en": "He is a clever boy.", "ko": "그는 영리한 소년이다."},
          {"en": "We are great players.", "ko": "우리는 훌륭한 연주자들이다."},
          {"en": "The weather is nice.", "ko": "날씨가 좋다."}
        ]
      },
      {
        "id": "g2",
        "title": "be동사 부정문과 의문문",
        "explanation": "부정문: be동사 + not (isn't, aren't). 의문문: be동사를 주어 앞으로 (Is he ~? / Are you ~?). 대답: Yes, 주어 + be. / No, 주어 + be + not.",
        "examples": [
          {"en": "I am not tired.", "ko": "나는 피곤하지 않다."},
          {"en": "She is not a teacher.", "ko": "그녀는 선생님이 아니다."},
          {"en": "Is Peter strong?", "ko": "피터는 힘이 센가요?"},
          {"en": "Are you a student? - Yes, I am.", "ko": "너는 학생이니? - 응, 그래."}
        ]
      },
      {
        "id": "g3",
        "title": "일반동사 현재형",
        "explanation": "일반동사는 동작이나 상태를 나타냅니다. 3인칭 단수 주어(he, she, it)일 때 동사에 -(e)s를 붙입니다. 규칙: 대부분 +s, -s/-x/-ch/-sh/-o → +es, 자음+y → y를 i로 고치고 +es, have → has",
        "examples": [
          {"en": "I like science.", "ko": "나는 과학을 좋아한다."},
          {"en": "She plays the guitar.", "ko": "그녀는 기타를 연주한다."},
          {"en": "He watches TV every day.", "ko": "그는 매일 TV를 본다."},
          {"en": "My mom studies English.", "ko": "엄마는 영어를 공부한다."},
          {"en": "Anne has a cat.", "ko": "앤은 고양이를 가지고 있다."}
        ]
      },
      {
        "id": "g4",
        "title": "일반동사 부정문과 의문문",
        "explanation": "부정문: don't/doesn't + 동사원형. 의문문: Do/Does + 주어 + 동사원형 ~? 3인칭 단수에는 does를 쓰고 동사는 반드시 원형으로!",
        "examples": [
          {"en": "I don't like iguanas.", "ko": "나는 이구아나를 좋아하지 않는다."},
          {"en": "She doesn't eat meat.", "ko": "그녀는 고기를 먹지 않는다."},
          {"en": "Do you play soccer?", "ko": "너는 축구를 하니?"},
          {"en": "Does he like strawberries?", "ko": "그는 딸기를 좋아하니?"}
        ]
      }
    ],
